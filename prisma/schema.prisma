generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id String @id @default(uuid())
  name String
  description String?
  price Decimal @db.Decimal(10,2)
  stock Int
  imageUrl String? @map("imageurl")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("products")
}
